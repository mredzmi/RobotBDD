{
  "name": "qa-bots",
  "displayName": "QA-Bots",
  "description": "AI-powered QA slash commands — works with any AI: GitHub Copilot, OpenAI, Claude, and more.",
  "version": "0.2.0",
  "publisher": "mredzmi",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing",
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "qa",
    "testing",
    "claude",
    "copilot",
    "openai",
    "ai",
    "bdd",
    "automation",
    "regression",
    "debug"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mredzmi/robotbdd"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "qa-bots.assistant",
        "name": "qa-bots",
        "fullName": "QA-Bots Assistant",
        "description": "AI-powered QA assistant — sanity, regression, test generation, debug, and PR review.",
        "isSticky": false,
        "commands": [
          {
            "name": "sanity",
            "description": "Run a sanity check on the current workspace"
          },
          {
            "name": "regression",
            "description": "Analyse recent git changes for regression risk"
          },
          {
            "name": "automate",
            "description": "Generate automated tests for the active file"
          },
          {
            "name": "debug",
            "description": "Debug an error or failing test — paste the stack trace"
          },
          {
            "name": "reviewPR",
            "description": "Review the current branch diff as a pull request"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "qa-bots.install",
        "title": "QA-Bots: Install Claude Code Commands",
        "category": "QA-Bots"
      },
      {
        "command": "qa-bots.sanity",
        "title": "QA-Bots: Run Sanity Check",
        "category": "QA-Bots"
      },
      {
        "command": "qa-bots.regression",
        "title": "QA-Bots: Run Regression Analysis",
        "category": "QA-Bots"
      },
      {
        "command": "qa-bots.automate",
        "title": "QA-Bots: Generate Automated Tests",
        "category": "QA-Bots"
      },
      {
        "command": "qa-bots.debug",
        "title": "QA-Bots: Debug Errors & Failing Tests",
        "category": "QA-Bots"
      },
      {
        "command": "qa-bots.reviewPR",
        "title": "QA-Bots: Review Pull Request",
        "category": "QA-Bots"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "qa-bots.automate",
          "when": "resourceExtname =~ /\\.(ts|js|py|java|go|rb|cs)$/",
          "group": "qa-bots@1"
        },
        {
          "command": "qa-bots.debug",
          "when": "resourceExtname =~ /\\.(ts|js|py|java|go|rb|cs)$/",
          "group": "qa-bots@2"
        }
      ]
    },
    "configuration": {
      "title": "QA-Bots",
      "properties": {
        "qa-bots.aiBackend": {
          "type": "string",
          "enum": [
            "vscode-lm",
            "openai",
            "claude-code"
          ],
          "enumDescriptions": [
            "Use any AI available in VS Code (GitHub Copilot, Claude, Gemini, etc.) — recommended",
            "Call the OpenAI API directly using your own API key",
            "Use the Claude Code CLI — installs .md files into .claude/commands/"
          ],
          "default": "vscode-lm",
          "description": "Which AI backend to use for QA-Bot commands."
        },
        "qa-bots.vscodeLmFamily": {
          "type": "string",
          "default": "",
          "description": "Preferred VS Code language model family (e.g. 'gpt-4o', 'claude-sonnet', 'gemini-pro'). Leave blank to let VS Code pick the best available model."
        },
        "qa-bots.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key. Required only when qa-bots.aiBackend is 'openai'."
        },
        "qa-bots.openaiModel": {
          "type": "string",
          "enum": [
            "gpt-4o",
            "gpt-4o-mini",
            "gpt-4-turbo",
            "gpt-3.5-turbo"
          ],
          "default": "gpt-4o",
          "description": "OpenAI model to use when backend is 'openai'."
        },
        "qa-bots.autoInstallOnActivation": {
          "type": "boolean",
          "default": true,
          "description": "Auto-install Claude Code command files into the workspace on startup (only relevant when backend is 'claude-code')."
        },
        "qa-bots.testFramework": {
          "type": "string",
          "enum": [
            "auto",
            "jest",
            "vitest",
            "pytest",
            "robot",
            "mocha",
            "jasmine",
            "junit"
          ],
          "default": "auto",
          "description": "Preferred test framework for /QA-automate. 'auto' detects from your project."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^9.9.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  }
}
